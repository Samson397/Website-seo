# Canonical URL, Open Graph, sitemap (set to your production URL)
NEXT_PUBLIC_SITE_URL=

# Google PageSpeed Insights — adds Lighthouse Core Web Vitals scores
PAGESPEED_API_KEY=

# DataForSEO — adds backlink data (referring domains, top link sources)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Monetization & growth (optional) ---

# Postgres for anonymized scan_events + consented email leads (Neon / Vercel / Supabase)
DATABASE_URL=

# Forward leads & scan events to Zapier / Make / n8n (JSON POST)
DATA_WEBHOOK_URL=

# Google AdSense — small on-page ads
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
