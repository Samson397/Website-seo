# Canonical URL, Open Graph, sitemap (set to your production URL)
NEXT_PUBLIC_SITE_URL=

# Google PageSpeed Insights — adds Lighthouse Core Web Vitals scores
PAGESPEED_API_KEY=

# DataForSEO — adds backlink data (referring domains, top link sources)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Scan data storage ---

# RECOMMENDED if you already have Neon on Vercel Storage:
# These are usually injected automatically when Neon is connected:
# DATABASE_URL=
# POSTGRES_URL=
# See docs/neon-setup.md

# Optional alternatives:
# KV_REST_API_URL= / KV_REST_API_TOKEN=   (Vercel KV — docs/vercel-kv-setup.md)
# FIREBASE_SERVICE_ACCOUNT=               (Firebase — docs/firebase-setup.md)

# Private insights API secret (required to call GET /api/insights)
# Generate with: openssl rand -hex 32
INSIGHTS_SECRET=

# Optional: also forward scan events to Zapier / Make / n8n
DATA_WEBHOOK_URL=

# Google AdSense — site script defaults to ca-pub-4587075434685102
# Optional override; leave blank to use the built-in publisher id
NEXT_PUBLIC_ADSENSE_CLIENT=
# Optional fixed display unit slot id (Auto ads work without this)
NEXT_PUBLIC_ADSENSE_SLOT=

# Stripe — $0.99 full SEO unlock (Checkout)
# Create a Price in Stripe Dashboard or via API, then set:
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRICE_DISPLAY=$0.99

# Optional promo codes that bypass Stripe (needs Neon DATABASE_URL)
# Format: CODE:MAX_USES,CODE:MAX_USES — defaults to FRIENDS:5,LAUNCH:10,VIP:3
# PROMO_CODES=FRIENDS:5,LAUNCH:10,VIP:3

# Resend — email reports + weekly watchlist digests
# https://resend.com (or Vercel Resend integration)
RESEND_API_KEY=
# Must be a verified domain sender, e.g. "SEOHub <reports@yourdomain.com>"
RESEND_FROM_EMAIL=
# Protects GET /api/cron/weekly-digest (Vercel Cron)
CRON_SECRET=
