# All checks work without any keys. These are optional extras:

# Canonical URL, Open Graph, sitemap (set to your production URL, e.g. https://yoursite.vercel.app)
NEXT_PUBLIC_SITE_URL=

# Google PageSpeed Insights — adds Lighthouse Core Web Vitals scores
PAGESPEED_API_KEY=

# DataForSEO — adds backlink data (referring domains, top link sources)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- SaaS (Stage 1: accounts, projects, monitoring) ---

# PostgreSQL connection (Neon, Supabase, or Vercel Postgres)
DATABASE_URL=postgresql://user:password@host:5432/seoscan

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Weekly cron job auth (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Email alerts via Resend (optional — alerts logged if unset)
RESEND_API_KEY=
EMAIL_FROM=SEOScan <alerts@yourdomain.com>
