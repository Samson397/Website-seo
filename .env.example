# Canonical URL, Open Graph, sitemap (set to your production URL)
NEXT_PUBLIC_SITE_URL=

# Google PageSpeed Insights — adds Lighthouse Core Web Vitals scores
PAGESPEED_API_KEY=

# DataForSEO — adds backlink data (referring domains, top link sources)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Scan data storage (pick one) ---

# RECOMMENDED: Vercel KV — create under Project → Storage → KV
# Vercel injects these automatically when you connect the store:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# See docs/vercel-kv-setup.md

# Optional alternative: Firebase Firestore
# FIREBASE_SERVICE_ACCOUNT=
# See docs/firebase-setup.md

# Private insights API secret (required to call GET /api/insights)
# Generate with: openssl rand -hex 32
INSIGHTS_SECRET=

# Optional: also forward scan events to Zapier / Make / n8n
DATA_WEBHOOK_URL=

# Google AdSense — small on-page ads
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
