# Canonical URL, Open Graph, sitemap (set to your production URL)
NEXT_PUBLIC_SITE_URL=

# Google PageSpeed Insights — adds Lighthouse Core Web Vitals scores
PAGESPEED_API_KEY=

# DataForSEO — adds backlink data (referring domains, top link sources)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Firebase (scan data storage) ---
# Easiest: paste the full service-account JSON from Firebase Console
# See docs/firebase-setup.md for click-by-click steps
FIREBASE_SERVICE_ACCOUNT=

# Or use separate fields instead of FIREBASE_SERVICE_ACCOUNT:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Optional: also forward scan events to Zapier / Make / n8n
DATA_WEBHOOK_URL=

# Google AdSense — small on-page ads
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
